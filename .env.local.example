# ─────────────────────────────────────────────────────────────
# Sweetarded Games — environment variables
# Copy this file to `.env.local` and fill in the values.
# All variables are exposed to the browser, so use the VITE_ prefix.
# ─────────────────────────────────────────────────────────────

# --- On-chain config (to be reconfigured later) ---
# Solana program ID for the Junk Pusher game (deployed on Gorbagana)
VITE_SOLANA_PROGRAM_ID=5gJkp3DsVTtBP6k7WtbiNBjQhAESgGrgu6AJfypMCAwe

# DEBRIS Token: mint DebrikgCUTkxMGSxnBoVuwqpW4zivMrUfUP6kUeNUMwy, 9 decimals, Gorbagana

# Game treasury wallet (public key holding DEBRIS for payouts)
VITE_GAME_TREASURY_WALLET=8iKCvwz3tyUp4hzxcyLYtPQghiwiEhiLDd38MEQBF6kR

# RPC endpoint (optional - defaults to Gorbagana RPC)
VITE_GORBAGANA_RPC=https://rpc.trashscan.io

# Game credit economy is NOT env-configurable — the shared starting stack
# (10,000 SWEET credits) lives in src/lib/credits.ts (STARTING_CREDITS), and
# per-action costs (drop 1 / bump 20) are defined in the game code. If you
# change STARTING_CREDITS, keep firestore.rules' caps in mind.

# Security settings
VITE_ENABLE_TOKEN_VALIDATION=true
VITE_ENABLE_WITHDRAWAL_PROTECTION=true
VITE_MAX_DEPOSIT_AMOUNT=1000000000000000
VITE_MAX_GAME_SCORE=999999999

# --- Audius music player (optional) ---
# The highlighted music feature streams from the public Audius API (no key
# needed). Override the featured artist handle or the app_name used in API
# requests if you want. Defaults: MATTRICKBEATS / Sweetardio.fun
# VITE_AUDIUS_HANDLE=MATTRICKBEATS
# VITE_AUDIUS_APP_NAME=Sweetardio.fun

# --- Sweetardio NFT mint countdown ---
# LaunchMyNFT controls whether minting is open and all transaction settings.
# Set this to the same scheduled instant to activate the site's countdown.
# Use ISO-8601 with Z or an explicit UTC offset; do not use a timezone-less date.
# VITE_MINT_START_AT=2026-08-01T18:00:00Z

# --- Firebase (whitelist signups, leaderboards / high scores) ---
# These default to the Sweetardio project in src/firebase.config.ts, so you only
# need to set them here to point at a DIFFERENT Firebase project. The web API key
# is public (it ships in the browser bundle); data is protected by Firestore rules.
VITE_FIREBASE_API_KEY=AIzaSyCM-j6N7elfsWz1JIOW2FnZZWiigsjncsE
VITE_FIREBASE_AUTH_DOMAIN=sweetardio.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=sweetardio
VITE_FIREBASE_STORAGE_BUCKET=sweetardio.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=35596243141
VITE_FIREBASE_APP_ID=1:35596243141:web:519f5efd5936da4a5020ac
