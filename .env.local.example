# ─────────────────────────────────────────────────────────────
# Sweetarded Games — environment variables
# Copy this file to `.env.local` and fill in the values.
# All variables are exposed to the browser, so use the VITE_ prefix.
# ─────────────────────────────────────────────────────────────

# --- On-chain config (to be reconfigured later) ---
# Solana program ID for the Junk Pusher game (deployed on Gorbagana)
VITE_SOLANA_PROGRAM_ID=5gJkp3DsVTtBP6k7WtbiNBjQhAESgGrgu6AJfypMCAwe

# DEBRIS Token: mint DebrikgCUTkxMGSxnBoVuwqpW4zivMrUfUP6kUeNUMwy, 9 decimals, Gorbagana

# Game treasury wallet (public key holding DEBRIS for payouts)
VITE_GAME_TREASURY_WALLET=8iKCvwz3tyUp4hzxcyLYtPQghiwiEhiLDd38MEQBF6kR

# RPC endpoint (optional - defaults to Gorbagana RPC)
VITE_GORBAGANA_RPC=https://rpc.trashscan.io

# Game configuration (optional - these are defaults)
# VITE_GAME_INITIAL_BALANCE=100
# VITE_GAME_BUMP_COST=50
# VITE_GAME_DROP_COST=1

# Security settings
VITE_ENABLE_TOKEN_VALIDATION=true
VITE_ENABLE_WITHDRAWAL_PROTECTION=true
VITE_MAX_DEPOSIT_AMOUNT=1000000000000000
VITE_MAX_GAME_SCORE=999999999

# --- Firebase (leaderboards / high scores) ---
# Without these the games still render; only the leaderboard features need them.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=trashmarket.fun
VITE_FIREBASE_PROJECT_ID=trashmarket-fun
VITE_FIREBASE_STORAGE_BUCKET=trashmarket-fun.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
