rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────
// Firestore security rules — REFERENCE for the whitelist signup form.
//
// ⚠️  This repo manages rules in the Firebase console (there is no firebase.json
//     deploy here). If you ALREADY have rules for other collections
//     (leaderboards, listings, game config, …), do NOT replace your whole
//     ruleset with this file — copy just the `match /whitelist/{wallet}` block
//     and the isValidWhitelistSignup() function into your existing
//     `match /databases/{database}/documents { … }`.
// ─────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Whitelist signups ──────────────────────────────────────────────
    // Anyone may submit (no auth required). Nobody can read / list / delete
    // from the client, so the wallet list stays private — view submissions in
    // the Firebase console (Firestore → Data → whitelist). Re-submitting the
    // same wallet just overwrites the document (idempotent).
    match /whitelist/{wallet} {
      allow read, delete: if false;
      allow create, update: if isValidWhitelistSignup(wallet);
    }

    function isValidWhitelistSignup(walletId) {
      let d = request.resource.data;
      return d.keys().hasOnly(['wallet', 'xHandle', 'submittedAt'])
        && d.wallet is string
        && d.wallet == walletId                       // doc id must equal the wallet
        && d.wallet.size() >= 32 && d.wallet.size() <= 44  // base58 Solana pubkey
        && (d.xHandle == null || (d.xHandle is string && d.xHandle.size() <= 40))
        && d.submittedAt == request.time;             // server timestamp only
    }

    // ── Arcade leaderboards ────────────────────────────────────────────
    // One document per player (keyed by wallet address, or an anonymous
    // free-play id). Publicly readable so the board renders for everyone;
    // writes are validated for shape and clamped to sane ranges. The board is
    // client-written, so it is NOT tamper-proof — these rules only stop
    // malformed / absurd documents, which is the standard arcade trade-off.
    match /leaderboard_slots/{player} {
      allow read: if true;
      allow create, update: if isValidLeaderboardEntry(player);
    }

    match /leaderboard_coinpusher/{player} {
      allow read: if true;
      allow create, update: if isValidLeaderboardEntry(player);
    }

    function isValidLeaderboardEntry(playerId) {
      let d = request.resource.data;
      return d.keys().hasOnly(['player', 'name', 'score', 'balance', 'netProfit', 'updatedAt'])
        && d.player is string
        && d.player == playerId                        // doc id must equal the player key
        && d.player.size() >= 1 && d.player.size() <= 64
        && d.name is string && d.name.size() <= 24
        && d.score is int && d.score >= 0 && d.score <= 1000000000000000
        && d.balance is int && d.balance >= 0 && d.balance <= 1000000000000000
        && d.netProfit is int
        && d.netProfit >= -1000000000000000 && d.netProfit <= 1000000000000000
        && d.updatedAt == request.time;                // server timestamp only
    }

    // ── The Board (notice board posts) ─────────────────────────────────
    // Publicly readable so every visitor sees the board. Client writes are
    // denied — the team pins new notes from the Firebase console
    // (Firestore → Data → board_posts → Add document). Fields used by the
    // site: title, body, tag, link, linkLabel, image, paper, published,
    // postedAt — see src/services/boardService.ts.
    match /board_posts/{post} {
      allow read: if true;
      allow write: if false;
    }

    // ── Your other collections ─────────────────────────────────────────
    // Keep whatever rules you already have for listings, game config, etc.
    // Anything not matched above is denied by default.
  }
}
