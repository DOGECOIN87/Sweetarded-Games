rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────
// Firestore security rules — REFERENCE for the whitelist signup form.
//
// ⚠️  This repo manages rules in the Firebase console (there is no firebase.json
//     deploy here). If you ALREADY have rules for other collections
//     (leaderboards, listings, game config, …), do NOT replace your whole
//     ruleset with this file — copy just the `match /whitelist/{wallet}` block
//     and the isValidWhitelistSignup() function into your existing
//     `match /databases/{database}/documents { … }`.
// ─────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Whitelist signups ──────────────────────────────────────────────
    // Anyone may submit (no auth required). Nobody can read / list / delete
    // from the client, so the wallet list stays private — view submissions in
    // the Firebase console (Firestore → Data → whitelist). Re-submitting the
    // same wallet just overwrites the document (idempotent).
    match /whitelist/{wallet} {
      allow read, delete: if false;
      allow create, update: if isValidWhitelistSignup(wallet);
    }

    function isValidWhitelistSignup(walletId) {
      let d = request.resource.data;
      return d.keys().hasOnly(['wallet', 'xHandle', 'submittedAt'])
        && d.wallet is string
        && d.wallet == walletId                       // doc id must equal the wallet
        && d.wallet.size() >= 32 && d.wallet.size() <= 44  // base58 Solana pubkey
        && (d.xHandle == null || (d.xHandle is string && d.xHandle.size() <= 40))
        && d.submittedAt == request.time;             // server timestamp only
    }

    // ── Your other collections ─────────────────────────────────────────
    // Keep whatever rules you already have for leaderboards, listings, etc.
    // Anything not matched above is denied by default.
  }
}
