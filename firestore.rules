rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────
// Firestore security rules — REFERENCE for the whitelist signup form.
//
// ⚠️  This repo manages rules in the Firebase console (there is no firebase.json
//     deploy here). If you ALREADY have rules for other collections
//     (leaderboards, listings, game config, …), do NOT replace your whole
//     ruleset with this file — copy just the `match /whitelist/{wallet}` block
//     and the isValidWhitelistSignup() function into your existing
//     `match /databases/{database}/documents { … }`.
// ─────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Whitelist signups ──────────────────────────────────────────────
    // Anyone may submit (no auth required). Reads are PUBLIC so The Board's
    // guest list can show who's whitelisted — note this makes every stored
    // wallet address and handle publicly queryable. If you'd rather keep the
    // list private again, set `allow read: if false;` (the guest-list section
    // on /board hides itself automatically when reads are denied).
    // Re-submitting the same wallet just overwrites the document (idempotent).
    match /whitelist/{wallet} {
      allow read: if true;
      allow delete: if false;
      allow create, update: if isValidWhitelistSignup(wallet);
    }

    function isValidWhitelistSignup(walletId) {
      let d = request.resource.data;
      return d.keys().hasOnly(['wallet', 'xHandle', 'submittedAt'])
        && d.wallet is string
        && d.wallet == walletId                       // doc id must equal the wallet
        && d.wallet.size() >= 32 && d.wallet.size() <= 44  // base58 Solana pubkey
        && (d.xHandle == null || (d.xHandle is string && d.xHandle.size() <= 40))
        && d.submittedAt == request.time;             // server timestamp only
    }

    // ── Arcade leaderboards ────────────────────────────────────────────
    // One document per player (keyed by wallet address, or an anonymous
    // free-play id). Publicly readable so the board renders for everyone.
    //
    // Anti-tamper posture (be honest about it): the games run entirely in the
    // browser, so a determined user can always call Firestore directly — a
    // client-written board can never be cryptographically tamper-proof
    // without a server. These rules instead BOUND the damage:
    //   • strict document shape + server-timestamp-only `updatedAt`
    //   • hard caps on every value (1e12)
    //   • rate limit: updates rejected within 2 s of the previous write
    //   • per-write delta caps: no single write can move score/balance/
    //     netProfit by more than 50 M (far above any legitimate jackpot,
    //     far below "type in a trillion")
    //   • score is monotonic — it can never be written downwards
    // Combined with the client HMAC on stored balances, casual DevTools
    // editing fails and scripted abuse is slow, capped, and obvious.
    // ALWAYS manually review top standings before paying out NFT-launch
    // rewards to specific wallets.
    match /leaderboard_slots/{player} {
      allow read: if true;
      allow create: if isValidLeaderboardEntry(player) && isSaneFirstEntry();
      allow update: if isValidLeaderboardEntry(player) && isSaneUpdate();
    }

    match /leaderboard_coinpusher/{player} {
      allow read: if true;
      allow create: if isValidLeaderboardEntry(player) && isSaneFirstEntry();
      allow update: if isValidLeaderboardEntry(player) && isSaneUpdate();
    }

    function isValidLeaderboardEntry(playerId) {
      let d = request.resource.data;
      return d.keys().hasOnly(['player', 'name', 'score', 'balance', 'netProfit', 'updatedAt'])
        && d.player is string
        && d.player == playerId                        // doc id must equal the player key
        && d.player.size() >= 1 && d.player.size() <= 64
        && d.name is string && d.name.size() <= 24
        && d.score is int && d.score >= 0 && d.score <= 1000000000000
        && d.balance is int && d.balance >= 0 && d.balance <= 1000000000000
        && d.netProfit is int
        && d.netProfit >= -1000000000000 && d.netProfit <= 1000000000000
        && d.updatedAt == request.time;                // server timestamp only
    }

    // A brand-new row can't claim more than one monster jackpot's worth.
    function isSaneFirstEntry() {
      let d = request.resource.data;
      return d.score <= 50000000
        && d.balance <= 50000000
        && d.netProfit >= -50000000 && d.netProfit <= 50000000;
    }

    // Updates: minimum 2 s since the last accepted write, bounded movement
    // per write, and the best score never goes down. Legacy docs written
    // before these rules may lack fields — treat missing values leniently
    // (the incoming write is still shape-validated and capped above).
    function isSaneUpdate() {
      let d = request.resource.data;
      let prev = resource.data;
      return (!('updatedAt' in prev) || prev.updatedAt == null
              || request.time.toMillis() >= prev.updatedAt.toMillis() + 2000)
        && (!('score' in prev) || !(prev.score is int)
            || (d.score >= prev.score && d.score - prev.score <= 50000000))
        && (!('balance' in prev) || !(prev.balance is int)
            || (d.balance - prev.balance <= 50000000 && prev.balance - d.balance <= 50000000))
        && (!('netProfit' in prev) || !(prev.netProfit is int)
            || (d.netProfit - prev.netProfit <= 50000000 && prev.netProfit - d.netProfit <= 50000000));
    }

    // ── The Board (notice board posts) ─────────────────────────────────
    // Publicly readable so every visitor sees the board. Client writes are
    // denied — the team pins new notes from the Firebase console
    // (Firestore → Data → board_posts → Add document). Fields used by the
    // site: title, body, tag, link, linkLabel, image, paper, published,
    // postedAt — see src/services/boardService.ts.
    match /board_posts/{post} {
      allow read: if true;
      allow write: if false;
    }

    // ── Your other collections ─────────────────────────────────────────
    // Keep whatever rules you already have for listings, game config, etc.
    // Anything not matched above is denied by default.
  }
}
